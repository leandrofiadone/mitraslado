---
const whatsappUrl =
  "https://wa.me/5491151127414?text=Hola%21%20Quiero%20asociarme%20a%20MiTraslado.";
---

<section id="asociarse" class="px-4 sm:px-6 md:px-8 pb-10 md:pb-14">
  <div
    class="max-w-6xl mx-auto border-[2.5px] border-filete-dorado grid grid-cols-1 md:grid-cols-2 overflow-hidden"
  >
    <div class="p-6 sm:p-8 md:p-10 bg-filete-ng2">
      <div class="flex items-center gap-3 md:gap-4 mb-[0.85rem]">
        <span class="w-[9px] h-[9px] bg-filete-rojo rotate-45 shrink-0"></span>
        <span
          class="text-[0.62rem] md:text-[0.65rem] tracking-[0.2em] uppercase text-filete-dorado font-semibold"
          >Para conductores</span
        >
      </div>
      <h3
        class="font-display text-[1.6rem] md:text-[1.85rem] font-black leading-[1.1] mb-[0.85rem]"
      >
        Manejá cuando<br />querés. <em class="italic text-filete-dorado"
          >Asociate hoy.</em
        >
      </h3>
      <p
        class="text-[0.85rem] text-filete-crema/60 leading-[1.65] font-light mb-6"
      >
        Sin exclusividad ni costo de entrada. Combinalo con otras apps mientras
        te convenga. Consultanos por la suscripción mínima y te pasamos los
        detalles.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 bg-filete-rojo text-filete-crema border-[1.5px] border-filete-dorado px-6 md:px-7 py-[0.85rem] font-body text-[0.85rem] font-semibold tracking-[0.07em] uppercase cursor-pointer hover:bg-[#A01015] no-underline"
      >
        <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current shrink-0">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
        Consultar por WhatsApp
      </a>
    </div>

    <div
      class="p-6 sm:p-8 md:p-10 bg-filete-ng3 border-t md:border-t-0 md:border-l border-filete-dorado/25 flex flex-col justify-center gap-5"
    >
      <div class="flex items-start gap-3">
        <span
          class="mt-[6px] w-[10px] h-[10px] bg-filete-dorado rotate-45 shrink-0"
        ></span>
        <div>
          <div class="font-display text-[1.05rem] font-bold text-filete-crema">
            100% del viaje
          </div>
          <div class="text-[0.82rem] text-filete-crema/55 leading-[1.55]">
            Lo que cobra el pasajero se queda con el conductor.
          </div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span
          class="mt-[6px] w-[10px] h-[10px] bg-filete-verde rotate-45 shrink-0"
        ></span>
        <div>
          <div class="font-display text-[1.05rem] font-bold text-filete-crema">
            Sumarte lleva 10 minutos
          </div>
          <div class="text-[0.82rem] text-filete-crema/55 leading-[1.55]">
            Verificación rápida y quedás activo.
          </div>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span
          class="mt-[6px] w-[10px] h-[10px] bg-filete-rojo rotate-45 shrink-0"
        ></span>
        <div>
          <div class="font-display text-[1.05rem] font-bold text-filete-crema">
            Foro de conductores
          </div>
          <div class="text-[0.82rem] text-filete-crema/55 leading-[1.55]">
            Acceso a la comunidad en WhatsApp.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
