---
const whatsapp = "+54 9 11 5112 7414";
const whatsappUrl =
  "https://wa.me/5491151127414?text=Hola%21%20Quiero%20asociarme%20a%20MiTraslado.";
const email = "contacto@mitraslado.com";
---

<section id="contacto" class="px-4 sm:px-6 md:px-8 py-10 md:py-14">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-3 md:gap-4 mb-[0.85rem]">
      <span class="w-[9px] h-[9px] bg-filete-verde rotate-45 shrink-0"></span>
      <span
        class="text-[0.62rem] md:text-[0.65rem] tracking-[0.2em] uppercase text-filete-dorado font-semibold"
        >Contacto</span
      >
      <span class="flex-1 h-px bg-filete-dorado/25"></span>
      <span class="w-[9px] h-[9px] bg-filete-rojo rotate-45 shrink-0"></span>
    </div>

    <h2
      class="font-display text-[1.75rem] sm:text-[2rem] md:text-[2.25rem] font-black leading-[1.1] tracking-[-0.01em] mb-8 md:mb-10"
    >
      Hablemos. <em class="italic text-filete-dorado">Estamos cerca.</em>
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-px bg-filete-dorado/20 border border-filete-dorado/25"
    >
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        class="bg-filete-negro p-5 md:p-6 no-underline block hover:bg-filete-ng3 transition-colors"
      >
        <div class="flex items-center gap-3 mb-2">
          <div
            class="w-7 h-7 bg-filete-verde flex items-center justify-center rotate-45 shrink-0"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-[14px] h-[14px] stroke-filete-crema fill-none -rotate-45"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
              ></path>
            </svg>
          </div>
          <div class="font-display text-[1rem] font-bold text-filete-crema">
            WhatsApp
          </div>
        </div>
        <div class="text-[0.85rem] text-filete-dorado font-medium">
          {whatsapp}
        </div>
        <div class="text-[0.75rem] text-filete-crema/50 mt-1">
          Respuesta rápida en horario comercial
        </div>
      </a>

      <a
        href={`mailto:${email}`}
        class="bg-filete-negro p-5 md:p-6 no-underline block hover:bg-filete-ng3 transition-colors"
      >
        <div class="flex items-center gap-3 mb-2">
          <div
            class="w-7 h-7 bg-filete-rojo flex items-center justify-center rotate-45 shrink-0"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-[14px] h-[14px] stroke-filete-crema fill-none -rotate-45"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="font-display text-[1rem] font-bold text-filete-crema">
            Email
          </div>
        </div>
        <div class="text-[0.85rem] text-filete-dorado font-medium break-all">
          {email}
        </div>
        <div class="text-[0.75rem] text-filete-crema/50 mt-1">
          Consultas, prensa y empresas
        </div>
      </a>

      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        class="bg-filete-negro p-5 md:p-6 no-underline block hover:bg-filete-ng3 transition-colors"
      >
        <div class="flex items-center gap-3 mb-2">
          <div
            class="w-7 h-7 bg-filete-dorado flex items-center justify-center rotate-45 shrink-0"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-[14px] h-[14px] stroke-filete-negro fill-none -rotate-45"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <div class="font-display text-[1rem] font-bold text-filete-crema">
            Foro
          </div>
        </div>
        <div class="text-[0.85rem] text-filete-dorado font-medium">
          Comunidad de conductores
        </div>
        <div class="text-[0.75rem] text-filete-crema/50 mt-1">
          Acceso al grupo de WhatsApp
        </div>
      </a>
    </div>
  </div>
</section>
