---
import Layout from "../layouts/Layout.astro";
import FileteBand from "../components/FileteBand.astro";

interface Requirement {
  readonly title: string;
  readonly body: string;
  readonly color: "rojo" | "verde" | "dorado" | "terracota";
}

const colorMap: Record<Requirement["color"], string> = {
  rojo: "bg-filete-rojo",
  verde: "bg-filete-verde",
  dorado: "bg-filete-dorado",
  terracota: "bg-filete-terracota",
};

const requirements: readonly Requirement[] = [
  {
    title: "Licencia de conducir",
    body: "Registro vigente con categoría profesional habilitante para el transporte de pasajeros en AMBA.",
    color: "rojo",
  },
  {
    title: "Vehículo autorizado",
    body: "Automóvil de 4 o 5 puertas, modelo 2014 en adelante, con aire acondicionado y en perfecto estado estético.",
    color: "verde",
  },
  {
    title: "Documentación al día",
    body: "Cédula verde/azul, VTV vigente, póliza de seguro para transporte de pasajeros y constancia de Monotributo.",
    color: "dorado",
  },
  {
    title: "Seguridad y antecedentes",
    body: "Certificado de Antecedentes Penales (nacional) con menos de 3 meses de antigüedad y validación biométrica.",
    color: "terracota",
  },
];

const whatsappUrl =
  "https://wa.me/5491151127414?text=Hola%21%20Quiero%20asociarme%20a%20MiTraslado.";
---

<Layout title="Asociate — MiTraslado">
  <FileteBand variant="rojo" slot="top-band" />

  <section class="px-4 sm:px-6 md:px-8 py-10 md:py-14">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-3 md:gap-4 mb-[0.85rem]">
        <span class="w-[9px] h-[9px] bg-filete-rojo rotate-45 shrink-0"></span>
        <span
          class="text-[0.62rem] md:text-[0.65rem] tracking-[0.2em] uppercase text-filete-dorado font-semibold"
          >Para conductores</span
        >
        <span class="flex-1 h-px bg-filete-dorado/25"></span>
      </div>

      <h1
        class="font-display text-[2rem] sm:text-[2.4rem] md:text-[2.8rem] font-black leading-[1.1] tracking-[-0.01em] mb-4"
      >
        Asociate. <em class="italic text-filete-dorado">Cuatro requisitos.</em>
      </h1>

      <p
        class="text-[0.95rem] text-filete-crema/55 leading-[1.65] max-w-[560px] mb-10 md:mb-12 font-light"
      >
        Quedate con el 100% de lo que generás. Suscripción fija, sin
        comisiones.
      </p>

      <ol
        class="list-none m-0 p-0 grid grid-cols-1 md:grid-cols-2 gap-px bg-filete-dorado/25 border border-filete-dorado/30"
      >
        {
          requirements.map((r, i) => (
            <li class="bg-filete-ng2 p-6 md:p-7 lg:p-8 flex gap-4 md:gap-5">
              <span
                class={`shrink-0 mt-1 w-7 h-7 ${colorMap[r.color]} rotate-45 flex items-center justify-center`}
              >
                <span class="-rotate-45 font-display text-[0.72rem] font-black text-filete-crema">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </span>
              <div class="min-w-0">
                <h3 class="font-display text-[1.1rem] md:text-[1.2rem] font-bold text-filete-crema mb-1.5">
                  {r.title}
                </h3>
                <p class="text-[0.9rem] text-filete-crema/60 leading-[1.65] font-light">
                  {r.body}
                </p>
              </div>
            </li>
          ))
        }
      </ol>

      <div
        class="mt-10 md:mt-12 flex flex-col md:flex-row md:items-center gap-4 md:gap-6"
      >
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-filete-rojo text-filete-crema border-[1.5px] border-filete-dorado px-7 py-[0.9rem] font-body text-[0.85rem] font-semibold tracking-[0.07em] uppercase cursor-pointer hover:bg-[#A01015] no-underline"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current shrink-0">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"
            ></path>
          </svg>
          Consultar por WhatsApp
        </a>
        <p class="text-[0.85rem] text-filete-crema/50 leading-[1.55] font-light">
          Te pasamos la suscripción mínima y los próximos pasos.
        </p>
      </div>
    </div>
  </section>

  <FileteBand variant="verde" />
</Layout>
